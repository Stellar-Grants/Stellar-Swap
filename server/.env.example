# Server port (default: 8000)
PORT=8000

# Allowed CORS origin — set to your frontend URL in production
# Example: https://your-app.vercel.app
CORS_ORIGIN=http://localhost:3000

# Stellar network to connect to: "testnet" or "mainnet"
# Default: testnet
STELLAR_NETWORK=testnet

# Soroban RPC URL — leave blank to use the default for STELLAR_NETWORK
# Testnet default: https://soroban-testnet.stellar.org
# Mainnet default: https://soroban-mainnet.stellar.org
STELLAR_RPC_URL=
