# Server port (default: 8000)
PORT=8000

# Allowed CORS origin — set to your frontend URL in production
# Example: https://your-app.vercel.app
CORS_ORIGIN=http://localhost:3000

# Stellar network to connect to: "testnet" or "mainnet"
# Default: testnet
STELLAR_NETWORK=testnet

# Horizon REST API URL for Classic Stellar operations — leave blank to use the default
# Testnet default: https://horizon-testnet.stellar.org
# Mainnet default: https://horizon.stellar.org
HORIZON_URL=
